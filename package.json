{
  "name": "scoutkit",
  "version": "0.1.0",
  "private": true,
  "description": "ScoutKit — a Teams/Slack-like meeting tool (contacts, persistent chat, LiveKit video) on Eclipse Scout",
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "build:lib": "npm run build --workspace=@scoutkit/livekit",
    "build:web": "npm run build --workspace=web",
    "build": "npm run build:lib && npm run build:web",
    "dev:lib": "npm run build:watch --workspace=@scoutkit/livekit",
    "dev:web": "npm run dev --workspace=web",
    "build:server": "mvn -f services/scoutkit-server/pom.xml -B -DskipTests package",
    "dev:server": "mvn -f services/scoutkit-server/pom.xml -B exec:java"
  },
  "engines": {
    "node": ">=25.0.0"
  }
}
