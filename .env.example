# --- LiveKit credentials (shared by livekit-server and token-server) ---
# These match LiveKit's built-in `--dev` key pair so local docker-compose works as-is.
# Generate strong, unique values for any real deployment (and drop `--dev`, see README).
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# --- Browser-facing LiveKit signaling URL ---
# Local docker-compose:  ws://localhost:7880
# Production / Coolify:   wss://livekit.example.com
LIVEKIT_URL=ws://localhost:7880

# --- PostgreSQL password (the real database) ---
# Used by both the `postgres` service and the scoutkit-server's JDBC connection.
# Fine to leave as-is for local docker-compose; set a strong value for any real deployment.
POSTGRES_PASSWORD=scoutkit
